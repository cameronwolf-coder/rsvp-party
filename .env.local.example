# ─── Google Apps Script Setup ───────────────────────────────────────────────
# 1. Create a Google Sheet with headers in row 1:
#    Timestamp | Name | Attending | RSVP'd At
# 2. Extensions → Apps Script → paste the code from deploy/Code.gs
# 3. Save, then Deploy → New deployment
#    - Type: Web app
#    - Execute as: Me
#    - Who has access: Anyone
# 4. Copy the Web app URL and paste it below
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID_HERE/exec
