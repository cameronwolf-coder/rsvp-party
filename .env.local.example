# ─── Google Sheets Setup ────────────────────────────────────────────────────
# 1. Create a Google Cloud project at https://console.cloud.google.com
# 2. Enable the Google Sheets API
# 3. Create a Service Account (IAM → Service Accounts → Create)
# 4. Download the JSON key, then base64-encode it:
#      base64 -i path/to/key.json | tr -d '\n'
# 5. Share your Google Sheet with the service account email
#    (looks like: rsvp-uploader@your-project.iam.gserviceaccount.com)
#    Give it "Editor" access.
# 6. Copy your sheet ID from the URL:
#    https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
# ─────────────────────────────────────────────────────────────────────────────

# Base64-encoded service account JSON key
GOOGLE_SERVICE_ACCOUNT_KEY=your_base64_encoded_service_account_key_here

# The spreadsheet ID from the Google Sheets URL
GOOGLE_SHEET_ID=your_google_sheet_id_here
